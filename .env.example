# ECOOPS Environment Configuration — Example
# Copy this to .env and fill in your API keys
# NEVER commit .env to git!

# GitLab Personal Access Token (needs api scope)
# Get one at: https://gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=your_gitlab_token_here

# Google Gemini API Key
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# GitLab Project ID (find it on your project's main page)
GITLAB_PROJECT_ID=80425527

# GitLab Base URL (default: https://gitlab.com)
GITLAB_BASE_URL=https://gitlab.com
